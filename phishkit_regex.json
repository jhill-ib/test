    "regex":"(?:date_default_timezone_set\\(|\\$t(?:ime)?z(?:one)?\\s{0,3}=)\\s{0,3}[\"']([^\"']+)",
    "category":"actor_indicator",
    "enabled": true
  },
  {
    "name":"php_variable",
    "regex":"\\$[a-z0-9]+\\s+\\.?=\\s+\"(.+)\"",
    "category":"kit_behavior",
    "enabled": true
  },
  {
    "name":"redirect",
    "regex":"(?:(?:window\\.|header\\([\"'])location(?:\\.href)?|http-equiv\\s{0,5}=\\s{0,5}\\\"Refresh\\\".+url)\\s{0,5}[:=]\\s{0,5}[\"']?([^<\"']+)[\"']",
    "category":"kit_behavior",
    "enabled": true
  },
  {
    "name":"url",
    "regex":"([fh][tx]{1,2}ps?://[a-z0-9/&\\?\\-=#\\.\\[\\]]+)",
    "category":"infrastructure",
    "enabled": false
  },
  {
    "name":"const_value",
